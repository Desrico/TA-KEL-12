APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=60

KAMPUS_API_BASE_URL=
KAMPUS_API_USERNAME=
KAMPUS_API_PASSWORD=
KAMPUS_API_STATIC_TOKEN=
KAMPUS_API_TIMEOUT=20

# Daftar admin CIS. USERNAMES/EMAILS/PEGAWAI_IDS bisa dipisah koma.
# Untuk NAMES, pakai titik koma jika lebih dari satu karena nama dapat berisi koma gelar.
# PEGAWAI_IDS dan JABATAN wajib diisi. Tanpa keduanya, login CIS tidak diberi akses admin.
# USERNAMES/EMAILS/NAMES hanya dipakai untuk mengikat identitas dan fallback saat endpoint pejabat CIS timeout.
CIS_ADMIN_PEGAWAI_IDS=
CIS_ADMIN_JABATAN=
CIS_ADMIN_USERNAMES=
CIS_ADMIN_EMAILS=
CIS_ADMIN_NAMES=
CIS_ADMIN_SPECIALIZATION="Staf Kemahasiswaan"

# Legacy fallback untuk instalasi lama.
CIS_KONSELOR_USERNAME=
CIS_KONSELOR_EMAIL=
CIS_KONSELOR_NAME=
