<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
                  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
                  id="Definitions_Edukasi" 
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Edukasi">
    <bpmn:participant id="Participant_Edukasi" name="Proses Edukasi Mental" processRef="Process_Edukasi" />
  </bpmn:collaboration>
  
  <bpmn:process id="Process_Edukasi" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Edukasi">
      <bpmn:lane id="Lane_Konselor" name="Konselor (Web Admin)">
        <bpmn:flowNodeRef>StartEvent_Edu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MengisiModul</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StatusModul</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetActive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetDraft</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sistem" name="Sistem (Laravel &amp; MongoDB)">
        <bpmn:flowNodeRef>Task_SaveMongo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SaveDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BroadcastAPI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Draft</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Mahasiswa" name="Mahasiswa (Mobile App)">
        <bpmn:flowNodeRef>Task_AccessMobile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReadModule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Edu</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    
    <bpmn:startEvent id="StartEvent_Edu" name="Ingin Membuat Modul">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:userTask id="Task_MengisiModul" name="Mengisi Data Modul">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="Gateway_StatusModul" name="Status Modul?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Publish</bpmn:outgoing>
      <bpmn:outgoing>Flow_Draft</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:userTask id="Task_SetActive" name="Atur Status: Active">
      <bpmn:incoming>Flow_Publish</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Task_SetDraft" name="Atur Status: Draft">
      <bpmn:incoming>Flow_Draft</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:serviceTask id="Task_SaveMongo" name="Simpan Modul Active ke MongoDB">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="Task_SaveDraft" name="Simpan Modul Draft ke MongoDB">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_EndDraft</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="Task_BroadcastAPI" name="Sediakan Modul di API Mobile">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:userTask id="Task_AccessMobile" name="Membuka Menu Edukasi Mobile">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Task_ReadModule" name="Membaca Konten Modul">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:endEvent id="EndEvent_Edu" name="Modul Selesai Dibaca">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:endEvent id="EndEvent_Draft" name="Draft Disimpan">
      <bpmn:incoming>Flow_EndDraft</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_Edu" targetRef="Task_MengisiModul" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_MengisiModul" targetRef="Gateway_StatusModul" />
    <bpmn:sequenceFlow id="Flow_Publish" name="Publish" sourceRef="Gateway_StatusModul" targetRef="Task_SetActive" />
    <bpmn:sequenceFlow id="Flow_Draft" name="Draft" sourceRef="Gateway_StatusModul" targetRef="Task_SetDraft" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_SetActive" targetRef="Task_SaveMongo" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_SetDraft" targetRef="Task_SaveDraft" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_SaveMongo" targetRef="Task_BroadcastAPI" />
    <bpmn:sequenceFlow id="Flow_EndDraft" sourceRef="Task_SaveDraft" targetRef="EndEvent_Draft" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_BroadcastAPI" targetRef="Task_AccessMobile" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_AccessMobile" targetRef="Task_ReadModule" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ReadModule" targetRef="EndEvent_Edu" />
  </bpmn:process>
  
  <bpmndi:BPMNDiagram id="BPMNDiagram_Edukasi">
    <bpmndi:BPMNPlane id="BPMNPlane_Edukasi" bpmnElement="Collaboration_Edukasi">
      <!-- Participant -->
      <bpmndi:BPMNShape id="Participant_Edukasi_di" bpmnElement="Participant_Edukasi" isHorizontal="true">
        <dc:Bounds x="150" y="80" width="1000" height="430" />
      </bpmndi:BPMNShape>
      
      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Konselor_di" bpmnElement="Lane_Konselor" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="970" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Sistem_di" bpmnElement="Lane_Sistem" isHorizontal="true">
        <dc:Bounds x="180" y="230" width="970" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Mahasiswa_di" bpmnElement="Lane_Mahasiswa" isHorizontal="true">
        <dc:Bounds x="180" y="370" width="970" height="140" />
      </bpmndi:BPMNShape>
      
      <!-- Shapes - Konselor -->
      <bpmndi:BPMNShape id="StartEvent_Edu_di" bpmnElement="StartEvent_Edu">
        <dc:Bounds x="210" y="137" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MengisiModul_di" bpmnElement="Task_MengisiModul">
        <dc:Bounds x="280" y="115" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_StatusModul_di" bpmnElement="Gateway_StatusModul" isMarkerVisible="true">
        <dc:Bounds x="410" y="130" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetActive_di" bpmnElement="Task_SetActive">
        <dc:Bounds x="490" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetDraft_di" bpmnElement="Task_SetDraft">
        <dc:Bounds x="490" y="145" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <!-- Shapes - Sistem -->
      <bpmndi:BPMNShape id="Task_SaveMongo_di" bpmnElement="Task_SaveMongo">
        <dc:Bounds x="620" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SaveDraft_di" bpmnElement="Task_SaveDraft">
        <dc:Bounds x="490" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BroadcastAPI_di" bpmnElement="Task_BroadcastAPI">
        <dc:Bounds x="750" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Draft_di" bpmnElement="EndEvent_Draft">
        <dc:Bounds x="630" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      
      <!-- Shapes - Mahasiswa -->
      <bpmndi:BPMNShape id="Task_AccessMobile_di" bpmnElement="Task_AccessMobile">
        <dc:Bounds x="750" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReadModule_di" bpmnElement="Task_ReadModule">
        <dc:Bounds x="880" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Edu_di" bpmnElement="EndEvent_Edu">
        <dc:Bounds x="1010" y="422" width="36" height="36" />
      </bpmndi:BPMNShape>
      
      <!-- Edges -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="246" y="155" />
        <di:waypoint x="280" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="380" y="155" />
        <di:waypoint x="410" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Publish_di" bpmnElement="Flow_Publish">
        <di:waypoint x="435" y="130" />
        <di:waypoint x="435" y="130" />
        <di:waypoint x="490" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Draft_di" bpmnElement="Flow_Draft">
        <di:waypoint x="435" y="180" />
        <di:waypoint x="435" y="185" />
        <di:waypoint x="490" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="590" y="130" />
        <di:waypoint x="670" y="130" />
        <di:waypoint x="670" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="540" y="225" />
        <di:waypoint x="540" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="720" y="300" />
        <di:waypoint x="750" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndDraft_di" bpmnElement="Flow_EndDraft">
        <di:waypoint x="590" y="300" />
        <di:waypoint x="630" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="800" y="340" />
        <di:waypoint x="800" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="850" y="440" />
        <di:waypoint x="880" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="980" y="440" />
        <di:waypoint x="1010" y="440" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
